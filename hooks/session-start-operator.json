{
  "description": "Inject stable operator profile context into Claude sessions",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/operator-config-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
