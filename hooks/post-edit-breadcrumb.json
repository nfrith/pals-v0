{
  "description": "Records which ALS systems and modules were touched during this session",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/als-breadcrumb.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
